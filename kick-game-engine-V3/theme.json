{
  "id": "kick-game-v3",
  "name": "Kick game (V3)",
  "author": "NUMU",
  "version": "0.3.5",
  "layout": "single-column",
  "description": "Kick Game (V3) — warm minimalist luxury streetwear, dense editorial grid, ported faithfully from the V2 in-tree theme.",
  "error_template": "templates/error.html",
  "loading_template": "templates/loading.html",
  "presets": {
    "templates": {
      "home": {
        "name": "Home",
        "sections": [
          {
            "type": "kghero",
            "settings": {
              "cta_link": "/products"
            }
          },
          {
            "type": "kgcategories",
            "settings": {}
          },
          {
            "type": "kgfeatured",
            "settings": {
              "view_all_link": "/products?tag=bestseller",
              "product_count": 8
            }
          },
          {
            "type": "kgpromo-banner",
            "settings": {
              "cta_link": "/products?category=accessories"
            }
          },
          {
            "type": "kgfeatured",
            "settings": {
              "view_all_link": "/products?tag=new",
              "product_count": 8
            }
          },
          {
            "type": "kgtestimonials",
            "settings": {
              "review_1_rating": 5,
              "review_2_rating": 5,
              "review_3_rating": 5
            }
          },
          {
            "type": "kgnewsletter",
            "settings": {}
          }
        ]
      },
      "product": {
        "name": "Product",
        "sections": [
          {
            "type": "kg-product-detail",
            "settings": {
              "show_rating": false,
              "show_stock": true,
              "show_guarantees": true,
              "show_related_products": true,
              "related_products_count": 4
            }
          }
        ]
      },
      "products": {
        "name": "Products",
        "sections": [
          {
            "type": "kg-products-page",
            "settings": {
              "show_view_toggle": false,
              "show_category_subtitle": false,
              "columns_desktop": 4,
              "columns_mobile": 2
            }
          }
        ]
      },
      "about": {
        "name": "About",
        "sections": [
          {
            "type": "kg-about",
            "settings": {}
          }
        ]
      },
      "contact": {
        "name": "Contact",
        "sections": [
          {
            "type": "kg-contact",
            "settings": {}
          }
        ]
      },
      "profile": {
        "name": "Profile",
        "sections": [
          {
            "type": "kg-profile",
            "settings": {}
          }
        ]
      },
      "cart": {
        "name": "Cart",
        "sections": []
      },
      "checkout": {
        "name": "Checkout",
        "sections": []
      },
      "order-confirmation": {
        "name": "Order confirmation",
        "sections": [
          {
            "type": "kg-order-confirmation",
            "settings": {
              "show_progress": false,
              "show_whatsapp": false,
              "show_track_order": false,
              "show_emoji": false
            }
          }
        ]
      }
    }
  }
}
