{
  "type": "kg-header",
  "name": "Header",
  "name_ar": "الهيدر",
  "tag": "header",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "id": "brand_name",
      "type": "text",
      "label": "Brand name (blank = store name)",
      "label_ar": "اسم العلامة (سيبه فاضي = اسم المتجر)",
      "default": ""
    },
    {
      "id": "brand_name_ar",
      "type": "text",
      "label": "Brand name (Arabic)",
      "label_ar": "اسم العلامة (بالعربي)",
      "default": ""
    },
    {
      "id": "logo_url",
      "type": "image_picker",
      "label": "Logo",
      "label_ar": "الشعار",
      "default": ""
    },
    {
      "id": "logo_height",
      "type": "range",
      "label": "Logo height (px)",
      "label_ar": "ارتفاع الشعار (بكسل)",
      "min": 20,
      "max": 48,
      "step": 2,
      "default": 32,
      "info": "Ignored when a logo shape is set in the theme's global settings."
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "id": "menu_handle",
      "type": "link_list_picker",
      "label": "Menu",
      "label_ar": "القائمة",
      "default": "main-menu",
      "info": "Menus are managed in Online store → Navigation. Leave as main-menu to use the store's primary menu."
    },
    {
      "id": "sticky",
      "type": "checkbox",
      "label": "Stick the header to the top on scroll",
      "label_ar": "تثبيت الهيدر فوق أثناء التمرير",
      "default": true
    },
    {
      "type": "header",
      "content": "Actions"
    },
    {
      "id": "show_search",
      "type": "checkbox",
      "label": "Show search",
      "label_ar": "إظهار البحث",
      "default": true
    },
    {
      "id": "show_account",
      "type": "checkbox",
      "label": "Show account",
      "label_ar": "إظهار الحساب",
      "default": true
    },
    {
      "id": "show_cart",
      "type": "checkbox",
      "label": "Show cart",
      "label_ar": "إظهار السلة",
      "default": true
    },
    {
      "type": "header",
      "content": "Announcement bar"
    },
    {
      "id": "show_announcement",
      "type": "checkbox",
      "label": "Show announcement bar",
      "label_ar": "إظهار شريط الإعلان",
      "default": true
    },
    {
      "id": "announcement_text",
      "type": "text",
      "label": "Announcement text",
      "label_ar": "نص الإعلان",
      "default": "",
      "visible_if": { "show_announcement": true }
    },
    {
      "id": "announcement_text_ar",
      "type": "text",
      "label": "Announcement text (Arabic)",
      "label_ar": "نص الإعلان (بالعربي)",
      "default": "",
      "visible_if": { "show_announcement": true }
    }
  ],
  "presets": [
    {
      "name": "Header",
      "name_ar": "الهيدر",
      "settings": {
        "menu_handle": "main-menu",
        "sticky": true,
        "show_search": true,
        "show_account": true,
        "show_cart": true,
        "show_announcement": true
      }
    }
  ]
}
