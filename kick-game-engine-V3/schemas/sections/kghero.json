    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Mobile image",
      "label_ar": "صورة الجوال",
      "aspect_ratio": "4/5",
      "visible_if": { "use_mobile_image": true },
      "info": "Recommended portrait, e.g. 1080×1350 (4:5). Leave blank to reuse the desktop image."
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
