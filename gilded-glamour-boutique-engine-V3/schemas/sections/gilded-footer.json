{
  "type": "gilded-footer",
  "name": "Gilded Footer",
  "name_ar": "تذييل جيلدد",
  "tag": "footer",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Brand",
      "content_ar": "العلامة التجارية"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "label_ar": "اسم المتجر",
      "default": "",
      "info": "Leave empty to use the store name."
    },
    {
      "type": "image_picker",
      "id": "logo_url",
      "label": "Logo",
      "label_ar": "الشعار",
      "default": "",
      "info": "Falls back to the store logo / brand name text."
    },
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Brand blurb",
      "label_ar": "نبذة المتجر",
      "default": ""
    },
    {
      "type": "header",
      "content": "Newsletter",
      "content_ar": "النشرة البريدية"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "label_ar": "إظهار الاشتراك بالنشرة",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter title",
      "label_ar": "عنوان النشرة",
      "default": "",
      "visible_if": "{{ section.settings.show_newsletter }}"
    },
    {
      "type": "text",
      "id": "newsletter_subtitle",
      "label": "Newsletter subtitle",
      "label_ar": "وصف النشرة",
      "default": "",
      "visible_if": "{{ section.settings.show_newsletter }}"
    },
    {
      "type": "header",
      "content": "Social links",
      "content_ar": "روابط التواصل"
