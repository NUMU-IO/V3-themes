          {
            "type": "gilded-footer",
            "settings": {}
          }
        ]
      },
      "page": {
        "name": "Page",
        "sections": [
          {
            "type": "gilded-header",
            "settings": {}
          },
          {
            "type": "gilded-rich-text",
            "settings": {}
          },
          {
            "type": "gilded-footer",
            "settings": {}
          }
