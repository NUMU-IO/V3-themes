{
  "id": "gilded-glamour-boutique-v3",
  "name": "Gilded glamour boutique (V3)",
  "author": "Saw Saw Atelier",
  "version": "0.4.1",
  "layout": "single-column",
  "description": "A bold, gold-accented luxury fashion theme with parallax hero, scroll-fill text animations, and curated vertical layouts. V3 port of the in-tree Gilded Glamour Boutique theme. Now with an editable Gilded header + footer included across every page.",
  "error_template": "templates/error.html",
  "loading_template": "templates/loading.html",
  "presets": {
    "templates": {
      "home": {
        "name": "Home",
        "sections": [
          {
            "type": "gilded-header",
            "settings": {}
          },
          {
            "type": "gilded-hero",
            "settings": {
              "cta_link": "/products",
              "enable_parallax": true
            }
          },
          {
            "type": "gilded-categories",
            "settings": {
              "max_items": 3
            }
          },
          {
            "type": "gilded-featured-collection",
            "settings": {
              "product_count": 5,
              "columns": 5,
              "view_all_link": "/products"
            }
          },
          {
            "type": "gilded-promo-banner",
            "settings": {}
          },
          {
            "type": "gilded-featured-collection",
            "settings": {
              "product_count": 5,
              "columns": 5,
              "view_all_link": "/products"
            }
          },
          {
            "type": "gilded-newsletter",
            "settings": {}
          },
          {
            "type": "gilded-footer",
            "settings": {}
          }
        ]
      },
      "product": {
        "name": "Product",
        "sections": [
          {
            "type": "gilded-header",
            "settings": {}
          },
          {
            "type": "gilded-product-detail",
            "settings": {
              "show_rating": true,
              "show_stock": true,
              "show_guarantees": true,
              "show_related_products": true,
              "related_products_count": 4
            }
          },
          {
            "type": "gilded-footer",
            "settings": {}
          }
        ]
      },
      "products": {
        "name": "Products",
        "sections": [
          {
            "type": "gilded-header",
            "settings": {}
          },
          {
            "type": "gilded-products-page",
            "settings": {
              "show_view_toggle": true,
              "columns_desktop": 4,
              "columns_mobile": 2
            }
          },
          {
            "type": "gilded-footer",
            "settings": {}
          }
        ]
      },
      "collection": {
        "name": "Collection",
        "sections": [
          {
            "type": "gilded-header",
            "settings": {}
          },
          {
            "type": "gilded-products-page",
            "settings": {
              "show_view_toggle": true,
              "columns_desktop": 4,
              "columns_mobile": 2
            }
          },
          {
            "type": "gilded-footer",
            "settings": {}
          }
        ]
      },
      "profile": {
        "name": "Profile",
        "sections": [
          {
            "type": "gilded-header",
            "settings": {}
          },
          {
            "type": "gilded-profile",
            "settings": {}
          },
          {
            "type": "gilded-footer",
            "settings": {}
          }
        ]
      },
      "cart": {
        "name": "Cart",
        "sections": [
          {
            "type": "gilded-header",
            "settings": {}
          },
          {
            "type": "gilded-footer",
            "settings": {}
          }
        ]
      },
      "checkout": {
        "name": "Checkout",
        "sections": [
          {
            "type": "gilded-header",
            "settings": {}
          },
          {
