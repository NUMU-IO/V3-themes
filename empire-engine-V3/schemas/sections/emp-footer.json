        { "type": "text", "id": "title", "label": "Column title", "label_ar": "عنوان العمود" },
        { "type": "text", "id": "link1_label", "label": "Link 1 label", "label_ar": "تسمية الرابط 1" },
        { "type": "url", "id": "link1_href", "label": "Link 1 URL", "label_ar": "رابط 1" },
        { "type": "text", "id": "link2_label", "label": "Link 2 label", "label_ar": "تسمية الرابط 2" },
        { "type": "url", "id": "link2_href", "label": "Link 2 URL", "label_ar": "رابط 2" },
        { "type": "text", "id": "link3_label", "label": "Link 3 label", "label_ar": "تسمية الرابط 3" },
        { "type": "url", "id": "link3_href", "label": "Link 3 URL", "label_ar": "رابط 3" },
        { "type": "text", "id": "link4_label", "label": "Link 4 label", "label_ar": "تسمية الرابط 4" },
        { "type": "url", "id": "link4_href", "label": "Link 4 URL", "label_ar": "رابط 4" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Empire Footer",
      "locales": { "en": { "name": "Empire Footer" }, "ar": { "name": "بازار تذييل" } },
      "settings": { "newsletter_title": "JOIN THE EMPIRE" },
      "blocks": [
        {
          "type": "column",
          "settings": {
            "title": "SHOP",
            "link1_label": "All Products", "link1_href": "/products",
            "link2_label": "New Arrivals", "link2_href": "/products?sort=newest",
            "link3_label": "Search", "link3_href": "/search"
          }
        },
        {
          "type": "column",
          "settings": {
            "title": "HELP",
            "link1_label": "Shipping", "link1_href": "/shipping",
            "link2_label": "Returns", "link2_href": "/returns",
            "link3_label": "Contact", "link3_href": "/contact"
          }
        }
      ]
    }
  ]
