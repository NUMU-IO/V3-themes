{
  "type": "emp-footer",
  "name": "Empire Footer",
  "name_ar": "بازار تذييل",
  "limit": 1,
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Brand name", "label_ar": "اسم المتجر", "default": "", "info": "Leave empty to use the store name." },
    { "type": "textarea", "id": "footer_text", "label": "Brand blurb", "label_ar": "نبذة المتجر", "default": "Handpicked essentials, made in Egypt. Bold design, honest prices." },
    { "type": "header", "content": "Newsletter" },
    { "type": "text", "id": "newsletter_title", "label": "Newsletter title", "label_ar": "عنوان النشرة", "default": "JOIN THE EMPIRE" },
    { "type": "textarea", "id": "newsletter_copy", "label": "Newsletter copy", "label_ar": "نص النشرة", "default": "Early access to limited drops, exclusive offers, and the seasonal edit." },
    { "type": "text", "id": "newsletter_button_label", "label": "Newsletter button", "label_ar": "زر النشرة", "default": "SUBSCRIBE" },
    { "type": "text", "id": "newsletter_button_success", "label": "Newsletter button (subscribed)", "label_ar": "زر النشرة (مشترك)", "default": "SUBSCRIBED" }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Link column",
      "name_ar": "عمود روابط",
