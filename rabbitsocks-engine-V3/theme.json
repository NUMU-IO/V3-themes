{
  "id": "rabbitsocks-v3",
  "name": "Mashkal",
  "author": "NUMU",
  "version": "0.4.1",
  "layout": "single-column",
  "description": "The kaleidoscope gallery theme: products framed in arches, diamonds and circles, with a built-in bundle builder and size chart.",
  "error_template": "templates/error.html",
  "loading_template": "templates/loading.html",
  "presets": {
    "templates": {
      "home": {
        "name": "Home",
        "sections": [
          {
            "type": "rs-header",
            "settings": {}
          },
          {
            "type": "rs-hero",
            "settings": {}
          },
          {
            "type": "rs-marquee",
            "settings": {}
          },
          {
            "type": "rs-categories",
            "settings": {}
          },
          {
            "type": "rs-gallery-wall",
            "settings": {}
          },
          {
            "type": "rs-featured",
            "settings": {}
          },
          {
            "type": "rs-pick-three",
            "settings": {}
          },
          {
            "type": "rs-fit-guide",
            "settings": {}
          },
          {
            "type": "rs-testimonials",
            "settings": {}
          },
          {
            "type": "rs-newsletter",
            "settings": {}
          },
          {
            "type": "rs-footer",
            "settings": {}
          }
        ]
      },
      "product": {
        "name": "Product",
        "sections": [
          {
            "type": "rs-header",
            "settings": {}
          },
          {
            "type": "rs-product-detail",
            "settings": {
              "show_rating": false,
              "show_stock": true,
              "show_guarantees": true,
              "show_related_products": true,
              "related_products_count": 4
            }
          },
          {
            "type": "rs-footer",
            "settings": {}
          }
        ]
      },
      "products": {
        "name": "Products",
        "sections": [
          {
            "type": "rs-header",
            "settings": {}
          },
          {
            "type": "rs-products-page",
            "settings": {
              "show_view_toggle": false,
              "columns_desktop": 4,
              "columns_mobile": 2
            }
          },
          {
            "type": "rs-footer",
            "settings": {}
          }
        ]
      },
