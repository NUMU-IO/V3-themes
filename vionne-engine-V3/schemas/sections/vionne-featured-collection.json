{
  "type": "vionne-featured-collection",
  "name": "Vionne Featured Collection",
  "settings": [
    { "type": "header", "content": "Content" },
    { "id": "title", "type": "text", "label": "Title", "default": "New arrivals" },
    { "id": "subtitle", "type": "text", "label": "Subtitle", "default": "" },
    { "id": "collection_tag", "type": "select", "label": "Collection", "default": "new",
      "options": [
        { "value": "new", "label": "New arrivals" },
        { "value": "bestseller", "label": "Best sellers" },
        { "value": "featured", "label": "Featured" }
      ] },
    { "id": "view_all_text", "type": "text", "label": "View all text", "default": "View all" },
    { "id": "view_all_link", "type": "url", "label": "View all link", "default": "/products" },

    { "type": "header", "content": "Layout" },
    { "id": "product_count", "type": "range", "label": "Products to show", "default": 8, "min": 2, "max": 12, "step": 1 },
    { "id": "columns", "type": "range", "label": "Columns", "default": 4, "min": 2, "max": 5, "step": 1 }
  ]
}
