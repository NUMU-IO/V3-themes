{
  "id": "editorial-v3",
  "name": "Manshet",
  "author": "NUMU",
  "version": "0.4.1",
  "layout": "single-column",
  "description": "Manshet (مانشيت) — the magazine theme. Front-page headlines in heavy uppercase type, editorial lookbook spreads, pull-quote testimonials and a newspaper masthead header, on warm paper with a deep editorial green and gold foil rules. For image-led fashion and lifestyle stores that want to read like a publication.",
  "error_template": "templates/error.html",
  "loading_template": "templates/loading.html",
  "presets": {
    "templates": {
      "404": {
        "name": "Not found",
        "sections": [
          {
            "type": "ed-header",
            "settings": {}
          },
          {
            "type": "ed-not-found",
            "settings": {}
          },
          {
            "type": "ed-footer",
            "settings": {}
          }
        ]
      },
      "home": {
        "name": "Home",
        "sections": [
          {
            "type": "ed-header",
            "settings": {}
          },
          {
            "type": "ed-hero",
            "settings": {
              "cta_link": "/products",
              "hero_image_url": ""
            }
          },
          {
            "type": "ed-marquee",
            "settings": {}
          },
          {
            "type": "ed-categories",
            "settings": {
              "max_items": 0
            }
          },
          {
            "type": "ed-featured-collection",
            "settings": {
              "collection_tag": "new",
