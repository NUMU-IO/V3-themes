    {
      "id": "cta_link",
      "type": "url",
      "label": "Primary Button Link",
      "label_ar": "رابط الزر الرئيسي",
      "default": "/products"
    },
    {
      "id": "secondary_text",
      "type": "text",
      "label": "Secondary Button Text",
      "label_ar": "نص الزر الثانوي",
      "default": ""
    },
    {
      "id": "secondary_link",
      "type": "url",
      "label": "Secondary Button Link",
      "label_ar": "رابط الزر الثانوي",
      "default": ""
    },
    {
      "type": "header",
      "content": "Media"
