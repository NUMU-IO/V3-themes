      "default": ""
    },
    {
      "type": "checkbox",
      "id": "use_mobile_image",
      "label": "Use a different image on mobile",
      "label_ar": "استخدام صورة مختلفة على الجوال",
      "default": false,
      "info": "Show a separate, portrait-friendly image on phones."
