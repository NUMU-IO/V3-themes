{
  "type": "bz-header",
  "name": "Bazar Header",
  "name_ar": "بازار ترويسة",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "label_ar": "اسم المتجر",
      "default": "",
      "info": "Leave empty to use the store name."
    },
    {
      "type": "image_picker",
      "id": "logo_url",
      "label": "Logo",
      "label_ar": "الشعار",
      "info": "Shown centered. Falls back to the brand name text."
    },
    {
      "type": "header",
      "content": "Announcement bar"
    },
    {
      "type": "checkbox",
      "id": "announcement_enabled",
      "label": "Show announcement bar",
      "label_ar": "إظهار شريط الإعلان",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "label_ar": "نص الإعلان",
      "default": "✦ Free shipping on orders over 1000 EGP",
      "info": "Write anything you like. Add more rotating messages as \"Announcement message\" blocks below."
    },
    {
      "type": "text",
      "id": "announcement_text_ar",
      "label": "Announcement text (Arabic)",
      "label_ar": "نص الإعلان (عربي)",
      "default": "✦ شحن مجاني للطلبات فوق ١٠٠٠ جنيه"
    },
    {
      "type": "select",
      "id": "announcement_mode",
      "label": "Animation",
      "label_ar": "الحركة",
      "default": "slide",
      "options": [
        {
          "value": "slide",
          "label": "Slide (rotate messages)",
          "label_ar": "تمرير (تبديل الرسائل)"
        },
        {
          "value": "static",
          "label": "Static (first message only)",
          "label_ar": "ثابت (الرسالة الأولى فقط)"
        }
      ]
    },
    {
      "type": "range",
      "id": "announcement_speed",
      "label": "Seconds per slide",
      "label_ar": "ثواني لكل شريحة",
      "default": 4,
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s"
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search icon",
      "label_ar": "إظهار أيقونة البحث",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "Show cart icon",
      "label_ar": "إظهار أيقونة السلة",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "nav_item",
      "name": "Navigation link",
      "name_ar": "رابط التنقل",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "label_ar": "التسمية"
        },
        {
          "type": "url",
          "id": "href",
          "label": "URL",
          "label_ar": "الرابط"
        }
      ]
    },
    {
      "type": "announcement",
      "name": "Announcement message",
      "name_ar": "رسالة إعلان",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Message",
          "label_ar": "النص"
        },
        {
          "type": "text",
          "id": "text_ar",
          "label": "Message (Arabic)",
          "label_ar": "النص (عربي)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)",
          "label_ar": "رابط (اختياري)"
        }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "Bazar Header",
      "locales": {
        "en": {
          "name": "Bazar Header"
        },
        "ar": {
          "name": "بازار ترويسة"
        }
      },
      "settings": {
        "announcement_enabled": true,
        "announcement_text": "✦ Free shipping on orders over 1000 EGP",
        "announcement_text_ar": "✦ شحن مجاني للطلبات فوق ١٠٠٠ جنيه",
        "announcement_mode": "slide",
        "announcement_speed": 4,
        "show_search": true,
        "show_cart": true
      },
      "blocks": [
        {
          "type": "nav_item",
          "settings": {
            "label": "",
            "href": "/"
          }
        },
        {
          "type": "nav_item",
          "settings": {
            "label": "",
            "href": "/products"
          }
        },
        {
          "type": "nav_item",
          "settings": {
            "label": "",
            "href": "/about"
          }
        },
        {
          "type": "nav_item",
          "settings": {
            "label": "",
            "href": "/contact"
          }
        }
      ]
    }
  ]
}